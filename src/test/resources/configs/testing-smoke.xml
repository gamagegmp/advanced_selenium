<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SmokeSuite">
    <test name="Smoke Tests">
        <!-- Run only tests tagged as 'smoke' across your whole test package -->
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <packages>
            <package name="com.adsel.functional"/>
        </packages>
    </test>
</suite>
